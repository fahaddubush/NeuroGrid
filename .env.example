# NeuroGrid runtime configuration. Copy to `.env` for your machine.
#
# All path entries below may be either absolute or relative. Relative paths
# resolve against WORKSPACE_ROOT (defaults to the repo root). This means the
# defaults below work portably without per-user editing.

# Override only if your repo lives at a non-standard location (e.g. inside a
# container with a fixed mount).
#WORKSPACE_ROOT=

# HEAPO 15-min smart meter CSV directory. The in-repo copy lives at:
HEAPO_DATA_DIR=data/raw/heapo_data/heapo_data/smart_meter_data/15min
# IANA timezone used when source CSV timestamps do not contain offsets.
HEAPO_TIMEZONE=Europe/Helsinki

# Long-term memory SQLite directory.
LTM_DB_DIR=data/district_logs

# Episodic memory journal directory.
EPISODIC_MEMORY_DIR=docs/system_memory/episodic

# Federated audit Parquet (Spark Byzantine round audit).
SPARK_AUDIT_DIR=artifacts/federated_audit

# District-tier durable state (PendingStore SQLite files).
DISTRICT_STATE_DIR=artifacts/federated_state
CITY_STATE_DIR=artifacts/federated_state

# Cross-process SharedMemory backend: memory | file | spark
NEUROGRID_SHARED_BACKEND=memory
NEUROGRID_SHARED_DIR=artifacts/shared_memory

# gRPC aggregator address.
AGGREGATOR_HOST=127.0.0.1
AGGREGATOR_PORT=50051

# Transport security. Loopback-only insecure transport is allowed for local
# development. Set NEUROGRID_TLS=1 for any networked deployment.
NEUROGRID_BIND_HOST=127.0.0.1
NEUROGRID_TLS=0
NEUROGRID_ALLOW_INSECURE=0
#NEUROGRID_CA_CERT=/secure/ca.pem
#NEUROGRID_SERVER_CERT=/secure/server.pem
#NEUROGRID_SERVER_KEY=/secure/server-key.pem
#NEUROGRID_CLIENT_CERT=/secure/client.pem
#NEUROGRID_CLIENT_KEY=/secure/client-key.pem
#NEUROGRID_ALLOWED_AGENTS=Bldg_001,District_01

# Local LLM. Non-loopback endpoints are rejected unless explicitly enabled;
# remote endpoints must use HTTPS.
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2:3b
NEUROGRID_ALLOW_REMOTE_LLM=0

# Optional round-level output-perturbation budget.
DP_MAX_EPSILON=inf

# Hadoop / winutils for Spark on Windows. The repo ships a copy at:
HADOOP_HOME=vendor/hadoop

# Spark tuning (optional).
#SPARK_MASTER=local[2]
#SPARK_DRIVER_MEMORY=2g
#SPARK_EXECUTOR_MEMORY=2g
#SPARK_SHUFFLE_PARTITIONS=4
#SPARK_DEFAULT_PARALLELISM=2
